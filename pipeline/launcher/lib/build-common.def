#------------------------------------------------------------------------------
# This container definition is appended to pipeline-level singularity.def files,
# after replacing __VAR_NAME__ with ${VAR_NAME}.
#------------------------------------------------------------------------------
# https://sylabs.io/guides/latest/user-guide/definition_files.html
#------------------------------------------------------------------------------
# STATIC_MDI_DIR=/srv/static/mdi is an mdi-centric, read-only MDI installation
# of SUITE_NAME created at build time. It is where the pipelines framework and 
# environments are drawn from. The framework is thus fixed at a version known 
# to support the suite/pipeline version.
#------------------------------------------------------------------------------
# ACTIVE_MDI_DIR=/srv/active/mdi is the user's calling MDI installation that is
# bind-mounted at run time, which is modifiable to add data and resource files, etc.
# It provides the MDI code for running apps, supported by STATIC_MDI_DIR.
#------------------------------------------------------------------------------
# TASK_DIR is a user-defined, active, read-write folder bind-mounted at run time. 
# In addition to being where pipelines deposit output files, TASK_DIR has the fixed, 
# static copy of the tool suite code used to execute a pipeline.
#------------------------------------------------------------------------------

# install the software required by pipeline actions as runtime environments
%post

    # variables set by mdi build
    export GIT_USER=__GIT_USER__
    export SUITE_NAME=__SUITE_NAME__
    export SUITE_VERSION=__SUITE_VERSION__
    export PIPELINE_NAME=__PIPELINE_NAME__
    export INSTALLER=__INSTALLER__
    export N_CPU=__N_CPU__

    # install common system utilities used by the MDI and many pipelines
    if [ "$INSTALLER" = "apt-get" ] || \
       [ "$INSTALLER" = "yum" ]; then
        $INSTALLER update && $INSTALLER install -y \
            git \
            wget \
            zip \
            time \
            nano \
            tree \
            curl
    else 
        echo "unknown installer: $INSTALLER"
        exit 1
    fi

    # path variables set by us
    export SRV_DIR=/srv
    export STATIC_DIR=${SRV_DIR}/static 
    export STATIC_MDI_DIR=${STATIC_DIR}/mdi 
    export STATIC_MDI=${STATIC_MDI_DIR}/mdi

    # execute an MDI-centric installation of the MDI itself
    mkdir -p ${STATIC_DIR}
    cd ${STATIC_DIR}
    git clone https://github.com/MiDataInt/mdi.git
    cd mdi
    ./install.sh 1

    # add the parent tool suite of this pipeline and its dependencies
    ${STATIC_MDI} add --suite ${GIT_USER}/${SUITE_NAME}
    cd ${STATIC_MDI_DIR}/suites/definitive/${SUITE_NAME}
    git -c advice.detachedHead=false checkout ${SUITE_VERSION}
    # TODO: checkout declared versions of any suite dependencies?
    cd ${SRV_DIR}

    # install micromamba to use for environment creation to reduce image size and speed builds
    export MMB_DIR=${STATIC_MDI_DIR}/bin/micromamba
    mkdir -p ${MMB_DIR}
    wget -qO- https://micro.mamba.pm/api/micromamba/linux-64/latest | tar -xj -C ${MMB_DIR} --strip-components=1 bin/micromamba
    export MICROMAMBA=${MMB_DIR}/micromamba

    # set channel_priority to strict
    ${MICROMAMBA} config set channel_priority strict

    # creata environments of the software required by the pipeline
    export IS_CONTAINER_BUILD=TRUE
    export CONDA_PLUGINS_AUTO_ACCEPT_TOS=true
    ${STATIC_MDI} ${PIPELINE_NAME} conda --create --force --version ${SUITE_VERSION} 

    # clean up packages to reduce image size
    ${MICROMAMBA} clean --all -y
    apt-get clean
    rm -rf /var/lib/apt/lists/*

# path overrides include all ways that running pipelines use files from mdi-pipelines-framework
# https://sylabs.io/guides/latest/user-guide/environment_and_metadata.html#environment-and-metadata
%environment 
    export LC_ALL=C
    export HAS_PIPELINES=true
    export HAS_APPS=false
    export MDI_IS_CONTAINER=TRUE
    export SRV_DIR=/srv

    # static, read only, code path specifications; environments, pipelines framework
    export STATIC_DIR=${SRV_DIR}/static 
    export STATIC_MDI_DIR=${STATIC_DIR}/mdi 
    export FRAMEWORK_DIR=${STATIC_MDI_DIR}/frameworks/definitive/mdi-pipelines-framework
    export JOB_MANAGER_DIR=${FRAMEWORK_DIR}/job_manager
    export LAUNCHER_DIR=${FRAMEWORK_DIR}/pipeline/launcher
    export WORKFLOW_DIR=${FRAMEWORK_DIR}/pipeline/workflow
    export WORKFLOW_SH=${WORKFLOW_DIR}/workflow.sh
    export SLURP=${FRAMEWORK_DIR}/shell/slurp

    # active, bind-mounted, read-write MDI directory
    export ACTIVE_MDI_DIR=${SRV_DIR}/active/mdi
    export MDI_DIR=${ACTIVE_MDI_DIR}

    # environment path specifications
    export ENVIRONMENTS_DIR=${STATIC_MDI_DIR}/environments
    export MICROMAMBA=${STATIC_MDI_DIR}/bin/micromamba/micromamba

# scriplet called by execute.pl to launch the pipeline; it takes no arguments
%runscript
    bash ${LAUNCHER_DIR}/lib/run-container.sh "$@"

# labels for the container image, displayed as 'singularity inspect __PIPELINE_NAME__-__PIPELINE_VERSION__.sif'
%labels
    Source Michigan Data Interface
    SuiteName __SUITE_NAME__
    SuiteVersion __SUITE_VERSION__
    PipelineName __PIPELINE_NAME__
    PipelineVersion __PIPELINE_VERSION__
    org.opencontainers.image.description Michigan Data Interface, __SUITE_NAME__:__SUITE_VERSION__, __PIPELINE_NAME__:__PIPELINE_VERSION__

# help text displayed by 'singularity run-help __PIPELINE_NAME__-__PIPELINE_VERSION__.sif'
%help
    Source:    Michigan Data Interface
    Suite:     __SUITE_NAME__:__SUITE_VERSION__
    Pipeline:  __PIPELINE_NAME__:__PIPELINE_VERSION__
